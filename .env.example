# =============================================================================
# Micro-GenBI 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# =============================================================================

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------
APP_NAME="Micro-GenBI"
APP_ENV="development"                    # development | staging | production
DEBUG=true
LOG_LEVEL="INFO"                         # DEBUG | INFO | WARNING | ERROR

# 服务端口
HOST="0.0.0.0"
PORT=8000
WORKERS=1

# -----------------------------------------------------------------------------
# 系统数据库（存储用户、配置、审计等系统数据）
# -----------------------------------------------------------------------------
# SQLite（开发/测试推荐，无需安装）
SYSTEM_DB_URL="sqlite:///./microgenbi.db"

# PostgreSQL（生产环境推荐）
# SYSTEM_DB_URL="postgresql+asyncpg://user:pass@localhost:5432/microgenbi"

# -----------------------------------------------------------------------------
# 业务数据库（用户配置的油库等业务数据库）
# -----------------------------------------------------------------------------
# 业务数据库通过页面配置，存储在系统数据库中
# 不在环境变量中配置，而是在租户管理界面中添加

# 连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# 多库配置（多库架构由用户按需配置，不在环境变量中固定）
# -----------------------------------------------------------------------------
# Micro-GenBI 支持三种查询模式，由 MultiDatabaseRouter 根据查询内容动态决定：
#
#   SINGLE     - 单库查询（指定 connection_id）
#   AGGREGATE  - 同构多库聚合（多库结构相同，自动聚合结果）
#   FEDERATED  - 异构跨库 JOIN（需配置 schema_registry 中的 cross_db_relations）
#
# 配置方式：通过管理界面为每个项目/用户组配置多个数据源连接，
# 系统自动路由，无需在此处指定。
#
# CONFIG_PATH="./genbi_config.yaml"  # 可选：使用 YAML 配置多库（替代数据库存储）

# -----------------------------------------------------------------------------
# LLM 配置（可选，默认通过系统数据库配置）
# -----------------------------------------------------------------------------
# 如果不通过页面配置，可以使用环境变量（单个租户场景）
# LLM 提供商: deepseek | openai | ollama
# LLM_PROVIDER="deepseek"

# DeepSeek 配置
# DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# DEEPSEEK_MODEL="deepseek-chat"

# OpenAI 配置（备选）
# OPENAI_API_KEY="sk-your-openai-api-key"
# OPENAI_MODEL="gpt-4o-mini"

# Ollama 配置（本地模型）
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3"

# -----------------------------------------------------------------------------
# IntentClassifier 配置（小模型兜底）
# -----------------------------------------------------------------------------
# 使用小模型进行意图分类（可选，节省成本）
ENABLE_MINI_CLASSIFIER=false
MINI_CLASSIFIER_MODEL="deepseek-chat"
MINI_CLASSIFIER_MAX_TOKENS=200

# -----------------------------------------------------------------------------
# Schema 配置
# -----------------------------------------------------------------------------
# 单库模式：使用 schema.yaml
SCHEMA_PATH="./schema.yaml"

# 多库模式：使用 schema_registry 目录
 SCHEMA_REGISTRY_PATH="./schema_registry"

# -----------------------------------------------------------------------------
# 可选：Redis 缓存
# -----------------------------------------------------------------------------
 REDIS_URL="redis://localhost:6379/0"
 CACHE_TTL=300

# -----------------------------------------------------------------------------
# 可选：LanceDB 记忆存储
# -----------------------------------------------------------------------------
 LANCEDB_PATH="./data/lancedb"
 EMBEDDING_MODEL="BAAI/bge-small-zh-v1.5"

# -----------------------------------------------------------------------------
# 可选：预测服务
# -----------------------------------------------------------------------------
 ENABLE_PREDICTION=false
 PREDICTOR="auto"                       # auto | prophet | statistics

# -----------------------------------------------------------------------------
# 安全配置
# -----------------------------------------------------------------------------
# API 密钥认证
# API_KEY="your-api-key-here"
# CORS_ORIGINS="http://localhost:3000,http://localhost:8501"

# -----------------------------------------------------------------------------
# 可观测性
# -----------------------------------------------------------------------------
# 结构化日志格式
 LOG_FORMAT="json"                      # text | json

# -----------------------------------------------------------------------------
# 性能调优
# -----------------------------------------------------------------------------
# 请求超时（秒）
REQUEST_TIMEOUT=60

# SQL 执行超时（秒）
SQL_TIMEOUT=30

# 最大 LIMIT
MAX_LIMIT=1000

# 最大 JOIN 数
MAX_JOIN_COUNT=10

# Token 预算
MAX_CONTEXT_TOKENS=3000
MAX_TABLES_IN_CONTEXT=5
